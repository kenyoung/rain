<?xml version="1.0" encoding="utf-8"?>
<!--
  Allow cleartext HTTP traffic ONLY to the RPi on the home LAN.
  Everything else on the device remains HTTPS-only.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.1.102</domain>
    </domain-config>
</network-security-config>
